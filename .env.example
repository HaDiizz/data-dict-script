# Database Configuration
DB_NAME=your_database_name
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mariadb # options: mariadb, postgres

# MongoDB Configuration (for NoSQL script)
MONGODB_URI=mongodb://localhost:27017/your_db

# Google Sheets Integration
# Paste the deployed Web App URL from Google Apps Script here
GOOGLE_SHEET_KEY=your_web_app_deployment_id

# Operational Settings
PORT=7777
AUTO_RUN=true # Set to true to run inspection immediately on startup
